<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence name="NavigateWithReplanning">
      <RateController hz="1.0">
        <ComputePathToPose goal="{goal}" path="{path}" planner_id="PlannerDiff" server_timeout="5000"/>
      </RateController>
      <FollowPath path="{path}" controller_id="FollowPathRearCartDiff" goal_checker_id="rear_cart_diff_goal_checker" server_timeout="5000"/>
    </PipelineSequence>
  </BehaviorTree>
</root>
