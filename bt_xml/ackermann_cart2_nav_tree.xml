<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence name="NavigateWithReplanning">
      <RateController hz="1.0">
        <ComputePathToPose goal="{goal}" path="{path}" planner_id="PlannerAckermann_cart2"/>
      </RateController>
      <FollowPath path="{path}" controller_id="FollowPathAckermann_cart2"/>
    </PipelineSequence>
  </BehaviorTree>
</root>